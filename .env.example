# Copy this file to .env and fill in values for local development
# Never commit .env to version control

# Path to local saved model directory (used if HF_MODEL_NAME is not set)
MODEL_DIR=model

# HuggingFace Hub model name (overrides MODEL_DIR when set)
# Set after uploading model with scripts/upload_to_hub.py
HF_MODEL_NAME=

# HuggingFace API token (needed for private repos or uploading)
HF_TOKEN=

# HuggingFace cache directory
HF_HOME=~/.cache/huggingface
